generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Thought {
  id         String    @id @default(cuid())
  title      String
  content    String
  /// 英文标题（LibreTranslate 自动翻译，随保存更新）
  titleEn    String?
  /// 法文标题
  titleFr    String?
  /// 英文正文
  contentEn  String?
  /// 法文正文
  contentFr  String?
  isPublic   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  comments   Comment[]
}

model Comment {
  id        String   @id @default(cuid())
  thoughtId String
  thought   Thought  @relation(fields: [thoughtId], references: [id], onDelete: Cascade)
  author    String
  content   String
  createdAt DateTime @default(now())
}

model Photo {
  id        String   @id @default(cuid())
  filename  String
  caption   String?
  isPublic  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model AccessRequest {
  id          String   @id @default(cuid())
  name        String
  contact     String?
  message     String?
  status      String   @default("pending") // pending | approved | rejected
  accessToken String?
  createdAt   DateTime @default(now())
}

/// 访客页面访问记录（由 middleware 写入，供管理员查看）
model VisitLog {
  id        String   @id @default(cuid())
  path      String
  ip        String?
  userAgent String?
  referer   String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}
