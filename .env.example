# 云端 PostgreSQL（Neon / Supabase / Railway 等控制台里复制连接串）
# 常见需加 SSL：postgresql://user:pass@host/db?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
ADMIN_PASSWORD=your_secure_password
ADMIN_USERNAME=admin

# 可选：DeepL 翻译 API（随想保存时自动生成英文/法文）。免费申请：https://www.deepl.com/pro-api
# DEEPL_AUTH_KEY=xxxx:fx
