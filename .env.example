# 云端 PostgreSQL（Neon / Supabase / Railway 等控制台里复制连接串）
# 常见需加 SSL：postgresql://user:pass@host/db?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
ADMIN_PASSWORD=your_secure_password
ADMIN_USERNAME=admin

# 可选：LibreTranslate（随想保存时自动生成英文/法文）
# 默认使用公共实例 https://libretranslate.com（有频率限制，生产建议自建：https://github.com/LibreTranslate/LibreTranslate）
# LIBRETRANSLATE_URL=https://libretranslate.com
# LIBRETRANSLATE_API_KEY=
# LIBRETRANSLATE_DISABLED=false

# 可选：访客访问记录签名密钥（middleware → /api/visit-logs）。生产环境务必设为长随机串；不填则生产环境不记录访问
# 服务端会解析 UA（浏览器/系统/设备）并对公网 IP 做地理查询（ip-api.com），Vercel 部署时可用边缘头补全国家/大区
# VISIT_LOG_SECRET=

# Vercel 部署时相册/随想插图需上传文件：在 Vercel → Storage → Blob 创建存储，将环境变量 BLOB_READ_WRITE_TOKEN 加入项目（本机开发可留空，使用 public/uploads）
# BLOB_READ_WRITE_TOKEN=
